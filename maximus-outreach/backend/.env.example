# Database
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/maximus_outreach

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
JWT_SECRET=change-this-to-a-random-64-character-string-before-production
ENCRYPTION_KEY=change-this-to-a-fernet-key-generate-with-cryptography-fernet

# CORS
CORS_ORIGINS=http://localhost:3000

# Environment
ENV=development
LOG_LEVEL=info

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Email tracking
TRACKING_BASE_URL=http://localhost:8000
